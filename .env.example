# UniFi Network MCP Server — environment variables
# Copy to .env and fill in values (or use config file mount instead)

UNIFI_HOST=192.168.1.1
UNIFI_API_KEY=your-api-key-here
UNIFI_VERIFY_SSL=false

# Optional: override server bind settings
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# Optional: override config file directory for docker-compose volume mount
# UNIFI_CONFIG_DIR=~/.config/unifi-mcp
