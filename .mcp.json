{
  "mcpServers": {
    "unifi-network": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project", "${CLAUDE_PLUGIN_ROOT}",
        "python", "${CLAUDE_PLUGIN_ROOT}/server.py"
      ],
      "env": {
        "UNIFI_HOST": "${UNIFI_HOST}",
        "UNIFI_API_KEY": "${UNIFI_API_KEY}",
        "UNIFI_VERIFY_SSL": "${UNIFI_VERIFY_SSL:-false}"
      }
    }
  }
}
