{
  "mcpServers": {
    "unifi-network": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project", "${CLAUDE_PLUGIN_ROOT}",
        "python", "${CLAUDE_PLUGIN_ROOT}/server.py"
      ],
      "env": {
        "UV_PROJECT_ENVIRONMENT": "${HOME}/.local/share/unifi-mcp/.venv"
      }
    }
  }
}
